    "@tanstack/react-query-devtools": "^5.62.0",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.468.0",
    "mapbox-gl": "^3.9.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.0",
    "elevenlabs": "^1.50.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
