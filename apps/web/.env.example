# FloodShield Main — Frontend Environment Variables (Template)
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to Git

# ── Mapbox GL JS ──────────────────────────────────────────
# Get from: https://account.mapbox.com/tokens/
# Free tier: 50k map loads/month
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# ── Supabase ───────────────────────────────────────────────
# Get from: https://supabase.com → Create Project → Settings → API
# ANON_KEY is public (RLS-protected), safe for frontend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Cloudflare Worker API ──────────────────────────────────
# Local dev: http://localhost:8787
# Production: https://floodshield-main-worker.workers.dev
VITE_API_BASE_URL=http://localhost:8787

# ── Solana ─────────────────────────────────────────────────
# Network: devnet (development), mainnet-beta (production)
VITE_SOLANA_NETWORK=devnet

# Program ID will be generated after deploying Anchor program
# Format: 4kkMUfH3L8XZEkrAYZX1QVV1Q7V7V7V7V7V7V7V7
VITE_PROGRAM_ID=your_solana_program_id_here

# ── ElevenLabs Voice Alerts ────────────────────────────────
# Voice ID for Vietnamese TTS (floodshield-main only)
VITE_ELEVENLABS_VOICE_ID=your_elevenlabs_voice_id_here
